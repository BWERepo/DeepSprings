{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "deepsprings",
  "compatibility_date": "2026-07-23",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  },
  "routes": [
    {
      "pattern": "deepsprings.businesswebexpress.com",
      "custom_domain": true
    }
  ]
}
